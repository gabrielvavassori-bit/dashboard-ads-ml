# Copie este arquivo para .env e preencha. NUNCA versione o .env real.

# URL publica do app (usada para marcar cookies como Secure quando em https)
APP_PUBLIC_URL=https://dashboard.unclicmarketplace.com.br

# Onde o SQLite vai gravar. Em producao no Render, use /var/data (persistent disk).
# Em desenvolvimento local, deixe em branco que ele cai em ./data.
DATA_DIR=/var/data

# Chave de assinatura do webhook Eduzz.
# Crie em https://integrations.eduzz.com/webhook/configs (aba "Chaves de acesso").
# Use a MESMA chave aqui e na configuracao do webhook.
EDUZZ_WEBHOOK_SECRET=cole_a_chave_secreta_aqui

# (Opcional) IDs dos produtos da Eduzz que esse app atende, separados por virgula.
# Se ficar vazio, qualquer evento da sua conta sera processado.
EDUZZ_PRODUCT_IDS=

# Dias de acesso ao ativar quando o evento nao traz proxima cobranca (default 32).
DEFAULT_ACCESS_DAYS=32

# Credenciais do painel admin. Quando o app subir, ele cria/atualiza o admin
# usando essas variaveis. Apos confirmar que entrou, voce pode remover a senha
# das variaveis de ambiente (o hash ja fica salvo no banco).
ADMIN_EMAIL=gabriel@unclicmarketplace.com.br
ADMIN_PASSWORD=defina_uma_senha_forte_aqui

# Limite por arquivo (em MB) e quantos dashboards gerar em paralelo
MAX_UPLOAD_MB=20
MAX_PARALLEL_DASHBOARDS=2

# Porta (Render/Railway injetam automaticamente, nao mexa em producao)
PORT=4182
